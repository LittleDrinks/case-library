{
  "name": "case-library-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test:unit": "vitest run tests/unit --environment jsdom",
    "test:e2e": "playwright test",
    "test:e2e:demo-media": "PLAYWRIGHT_OUTPUT_DIR=../agent-runs/demo-media PLAYWRIGHT_VIDEO=on playwright test tests/demo-media.spec.js --project=chromium-desktop",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "vite": "^7.2.7",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.4"
  }
}
